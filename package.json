{
  "name": "dathere-design-system",
  "version": "1.0.0",
  "private": true,
  "description": "datHere design system — Carbon white theme",
  "scripts": {
    "build:tokens": "sass src/styles/main.scss colors_and_type.css --style=expanded --no-source-map --load-path=node_modules",
